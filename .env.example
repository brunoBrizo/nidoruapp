# Local development only. Do not put production credentials in this file.
# Blank optional integration values mean disabled local stand-ins.
APP_ENV=development

# Supabase local Docker stack.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=<copy-from-pnpm-supabase-status>
SUPABASE_SECRET_KEY=<copy-from-pnpm-supabase-status-local-only>
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Cloudflare R2 or local S3-compatible mock for development media.
R2_ENDPOINT=
R2_BUCKET=nidoru-dev-media
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=

# RevenueCat server-side development fixtures.
REVENUECAT_SECRET_API_KEY=
REVENUECAT_WEBHOOK_AUTHORIZATION=<development-only-webhook-authorization>

# PostHog is disabled locally unless a development project key is supplied.
POSTHOG_PROJECT_API_KEY=
POSTHOG_HOST=

# Sentry is disabled locally unless a development DSN is supplied.
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_URL=

# Resend must stay in test mode before public launch.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_TEST_RECIPIENT=

# Help Scout public launch support workflow placeholder.
HELP_SCOUT_MAILBOX_ID=
HELP_SCOUT_SUPPORT_EMAIL=support@example.invalid
