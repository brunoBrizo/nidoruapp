# Mobile public development values only. EXPO_PUBLIC_* values are embedded in the app.
EXPO_PUBLIC_APP_ENV=development
EAS_PROJECT_ID=

EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<copy-from-pnpm-supabase-status>

# Remote media is disabled locally unless a development public base URL is supplied.
EXPO_PUBLIC_R2_PUBLIC_BASE_URL=

# RevenueCat SDK keys are public, but must still be environment-specific.
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=

# PostHog explicit-event analytics is disabled locally unless a development key is supplied.
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=

# Sentry crash reporting is disabled locally unless a development DSN is supplied.
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_RELEASE=
EXPO_PUBLIC_SENTRY_DIST=

# Non-production only. Enables /observability-proof buttons for Sentry/PostHog proof events.
EXPO_PUBLIC_OBSERVABILITY_PROOF_MODE=false

# Local support fallback. Production must use the Help Scout launch inbox.
EXPO_PUBLIC_SUPPORT_EMAIL=support@example.invalid
