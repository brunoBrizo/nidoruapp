{
  "name": "@nidoru/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "eas:config": "eas config --profile development --platform ios --non-interactive",
    "eas:build:development": "eas build --profile development",
    "eas:build:preview": "eas build --profile preview",
    "eas:build:production": "eas build --profile production",
    "eas:submit:production": "eas submit --profile production",
    "eas:update:development": "eas update --branch development",
    "eas:update:preview": "eas update --branch preview",
    "eas:update:production": "eas update --branch production",
    "sentry:sourcemaps:update": "sentry-expo-upload-sourcemaps dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --max-warnings=0",
    "test": "pnpm run test:unit && pnpm run test:component && pnpm run test:sqlite",
    "test:unit": "jest --runInBand --selectProjects unit",
    "test:component": "jest --runInBand --selectProjects component",
    "test:sqlite": "deno test --allow-run=sqlite3 --allow-read --allow-write tests/sqlite-migrations.test.ts"
  },
  "dependencies": {
    "@nidoru/domain": "workspace:*",
    "@nidoru/i18n": "workspace:*",
    "@nidoru/ui-tokens": "workspace:*",
    "@sentry/react-native": "~7.2.0",
    "@supabase/supabase-js": "^2.106.0",
    "@tanstack/react-query": "^5.100.11",
    "expo": "~54.0.34",
    "expo-audio": "~1.1.1",
    "expo-brightness": "~14.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-localization": "~17.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.17",
    "lucide-react-native": "^1.16.0",
    "posthog-react-native": "^4.45.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-purchases": "^10.1.1",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.17",
    "eas-cli": "^18.13.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17"
  }
}
