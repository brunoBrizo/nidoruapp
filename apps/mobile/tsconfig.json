{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": "../..",
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@nidoru/domain": ["packages/domain/src/index.ts"],
      "@nidoru/i18n": ["packages/i18n/src/index.ts"],
      "@nidoru/ui-tokens": ["packages/ui-tokens/src/index.ts"],
      "@nidoru/validation": ["packages/validation/src/index.ts"]
    },
    "strict": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "src/nativewind-env.d.ts"
  ]
}
