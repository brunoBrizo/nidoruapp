# Web public development values only. NEXT_PUBLIC_* values are exposed to browsers.
NEXT_PUBLIC_APP_ENV=development

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<copy-from-pnpm-supabase-status>

# Web analytics and monitoring stay disabled locally unless development keys are supplied.
NEXT_PUBLIC_POSTHOG_API_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_SENTRY_DSN=

# Local support fallback. Production must use the Help Scout launch inbox.
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.invalid
