{
  "name": "nidoru",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "pnpm": {
    "overrides": {
      "lightningcss": "1.30.1"
    }
  },
  "scripts": {
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:component": "turbo run test:component",
    "test:sqlite": "turbo run test:sqlite",
    "test:revenuecat:webhooks": "node --test supabase/tests/revenuecat/revenuecat-webhook-fixtures.test.mjs",
    "i18n:check": "pnpm --filter @nidoru/i18n check:keys",
    "loadtest:k6:backend": "k6 run load-tests/k6/backend-smoke.js",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:db:reset": "supabase db reset",
    "supabase:db:lint": "supabase db lint --local --fail-on warning",
    "supabase:migrations:validate": "supabase db reset",
    "supabase:migrations:list": "supabase migration list --local",
    "supabase:test:db": "supabase test db --local supabase/tests/database",
    "supabase:functions:serve": "supabase functions serve foundation-health",
    "supabase:functions:test": "deno test --allow-env supabase/functions/tests",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@nidoru/config": "workspace:*",
    "deno": "^2.7.14",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "supabase": "^2.100.0",
    "turbo": "^2.6.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0"
  }
}
