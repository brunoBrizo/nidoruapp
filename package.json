{
  "name": "nidoru",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:db:reset": "supabase db reset",
    "supabase:migrations:list": "supabase migration list --local",
    "supabase:test:db": "supabase test db --local supabase/tests/database",
    "supabase:functions:serve": "supabase functions serve foundation-health",
    "supabase:functions:test": "deno test --allow-env supabase/functions/tests",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@nidoru/config": "workspace:*",
    "deno": "^2.7.14",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "supabase": "^2.100.0",
    "turbo": "^2.6.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0"
  }
}
